IMPORT "env" "textUtf8" AS textUtf8 (I32 ptr, len, x, y)

ACCESSOR len : s [-1+x]

VAR (*This is a simple comment*)
I32 hello := "Hello,",
    world := "world! FOO BAR BAZ",
F64 bar := 6.9
END

(*
 This is a comment
 (*
   And this is a nested comment
   And they both work
 *)
 They are ignored at the lexer level
 And neither of them breaks line/character count of following tokens
 lel
*)
(**)

PROC start
EXPORT "start"
DO
  (* length is stored as s ingle I32 before string 
     so we trim " FOO BAR BAZ" *)
  s.len|world := 6
END

PROC update
EXPORT "update"
I32 hx := 10, hy := 10,
    wx := 20, wy := 40,
DO
  textUtf8(hello, s.len|hello, hx, hy);
  textUtf8(world, s.len|world, wx, wy);
END

PROC foo : I32
I64 bar := 2
DO
  bar := bar + 35;
  RETURN bar + 42
END
PROC baz DO RETURN END
