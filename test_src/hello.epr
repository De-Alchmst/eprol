IMPORT "env" "textUtf8" AS textUtf8 (I32 ptr, len, x, y)

VAR
I32 hello := "Hello,",
    world := "world!",
    helloLen := 6,
    worldLen := 6,
F64 bar := 6.9
END

PROC start
EXPORT "start"
DO END

PROC update
EXPORT "update"
I32 hx := 10, hy := 10,
    wx := 20, wy := 40,
DO
  textUtf8(hello, helloLen, hx, hy);
  textUtf8(world, worldLen, wx, wy);
END

PROC foo : I32
I64 bar := 2
DO
  bar := bar + 35;
  RETURN bar + 42
END
PROC baz DO RETURN END
