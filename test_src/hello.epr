IMPORT "env" "textUtf8" AS textUtf8 (I32 ptr, len, x, y)

VAR
I32 hello := "Hello,",
    world := "world!",
    helloLen := 6,
    worldLen := 6,
END

PROC start
EXPORT "start"
DO END

PROC update
EXPORT "update"
I32 hx := 10, hy := 10,
    wx := 20, wy := 40,
DO
  dfdsf dstextU
  textUtf8(hello, helloLen, hx, hy);
  textUtf8(world, worldLen, wx, wy)
END

