IMPORT "console" "log" AS log : console (I32 sre, len)
IMPORT "js" "var1" AS var1 I32

VAR : foo
I32 bar, baz,
    bax := 42
F64 bach := 4.2
END

VAR F32 bar := 10 END

VAR : greet
I32  h := "Hello,",
     w := "world!"
END

PROC foo : bar (I32 a, b, I64 c)
EXPORT "foo"
I32 x := 20, y := x
CONST z = 30
VAR I64 w := z
DO
  foo((a+b), x);
  0
END


PROC foo(I32 a, b) : I32
DO
  a
END
