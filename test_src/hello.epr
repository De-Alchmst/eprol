IMPORT "console" "log" AS log : console (I32 sre, len)
IMPORT "js" "var1" AS var1 I32
IMPORT "env" "textUtf8" AS textUtf8 (I32 ptr, len, x, y)

VAR
I32 hello := "Hello,",
    world := "world!",
    helloLen := 6,
    worldLen := 6,
END

PROC start
EXPORT "start"
DO END

PROC update
EXPORT "update"
I32 hx := 10, hy := 10,
    wx := 20, wy := 40,
DO
  textUtf8(hello, 6, hx, hy);
  textUtf8(world, 6, wx, wy)
END
